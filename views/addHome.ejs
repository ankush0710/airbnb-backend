<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>airbnb-addHome</title>
    <style>
        body {
            margin: 0;
            font-family: Inter, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
            background: linear-gradient(180deg, #eef2ff 0%, #f8fafc 100%);
            color: #0f172a;
        }

        .navbar {
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding: 1rem 2rem;
            background: #1d4ed8;
            color: #fff;
            box-shadow: 0 6px 18px rgba(15, 23, 42, 0.12);
        }


        .navItems {
            color: #fff;
            text-decoration: none;
            margin-left: 1.25rem;
            font-weight: 600;
        }

        .navItems:hover {
            text-decoration: underline;
        }

        .navActiveItems {
            text-decoration: underline;
            font-weight: 800;
            color: #fff;
            text-underline-offset: 4px;
        }

        .container {
            max-width: 560px;
            margin: 3rem auto;
            padding: 0 1.25rem;
        }

        .card {
            background: #ffffff;
            border-radius: 24px;
            padding: 2rem 4rem;
            box-shadow: 0 18px 35px rgba(15, 23, 42, 0.08);
            border: 1px solid rgba(148, 163, 184, 0.18);
        }

        .card h2 {
            margin-top: 0;
            font-size: 1.85rem;
            color: #0f172a;
        }

        .form-row {
            display: grid;
            gap: 1rem;
            margin-top: 1.5rem;
        }

        input[type="text"] {
            width: 100%;
            padding: 0.95rem 1rem;
            border-radius: 14px;
            border: 1px solid #cbd5e1;
            font-size: 1rem;
            color: #0f172a;
            outline: none;
        }

        input[type="text"]:focus {
            border-color: #2563eb;
            box-shadow: 0 0 0 4px rgba(59, 130, 246, 0.15);
        }

        input[type="number"] {
            width: 100%;
            padding: 0.95rem 1rem;
            border-radius: 14px;
            border: 1px solid #cbd5e1;
            font-size: 1rem;
            color: #0f172a;
            outline: none;
        }

        input[type="number"]:focus {
            border-color: #2563eb;
            box-shadow: 0 0 0 4px rgba(59, 130, 246, 0.15);
        }

        button {
            width: 100%;
            padding: 0.95rem 1.25rem;
            background: #1d4ed8;
            color: #fff;
            border: none;
            border-radius: 14px;
            cursor: pointer;
            font-size: 1rem;
            font-weight: 700;
            transition: background 0.2s ease;
        }

        button:hover {
            background: #1e40af;
        }

        .helper {
            margin: 0.5rem 0 0;
            color: #475569;
            line-height: 1.6;
        }
    </style>
</head>

<body>
    <header class="navbar">
        <div class="brand">Airbnb Clone</div>
        <nav>
            <a href="/host/add-home" class="<%= currentPage == 'addHome' ? 'navActiveItems' : 'navItems'%>">Add Home</a>
            <a href="/" class="navItems">Go To Home</a>
        </nav>
    </header>

    <main class="container">
        <section class="card">
            <h2>Add Your Home</h2>
            <p class="helper">Submit a home name to add it to the registered homes list.</p>
            <form action="/host/add-home" method="POST" class="form-row">
                <input type="text" name="homeName" placeholder="Enter your home name" required />
                <input type="number" name="price" placeholder="Enter price per night" required />
                <input type="text" name="location" placeholder="Enter your home location" required />
                <input type="number" name="ratings" placeholder="Ratings" required />
                <input type="text" name="imageUrl" placeholder="Enter Image URL" required />
                <button type="submit">Submit</button>
            </form>
        </section>
    </main>
</body>

</html>