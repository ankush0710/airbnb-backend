<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>airbnb-addHome</title>
    <style>
        .container {
            max-width: 560px;
            margin: 2rem auto;
            padding: 0 1.25rem;
            box-sizing: border-box;
        }

        .card {
            background: #ffffff;
            border-radius: 24px;
            padding: 2rem 4rem;
            box-shadow: 0 18px 35px rgba(15, 23, 42, 0.08);
            border: 1px solid rgba(148, 163, 184, 0.18);
        }

        .card h2 {
            margin-top: 0;
            font-size: 1.85rem;
            color: #0f172a;
        }

        .form-row {
            display: grid;
            gap: 1rem;
            margin-top: 1.5rem;
        }

        input[type="text"] {
            width: 100%;
            padding: 0.95rem 1rem;
            border-radius: 14px;
            border: 1px solid #cbd5e1;
            font-size: 1rem;
            color: #0f172a;
            outline: none;
        }

        input[type="text"]:focus {
            border-color: #2563eb;
            box-shadow: 0 0 0 4px rgba(59, 130, 246, 0.15);
        }

        input[type="number"] {
            width: 100%;
            padding: 0.95rem 1rem;
            border-radius: 14px;
            border: 1px solid #cbd5e1;
            font-size: 1rem;
            color: #0f172a;
            outline: none;
        }

        input[type="number"]:focus {
            border-color: #2563eb;
            box-shadow: 0 0 0 4px rgba(59, 130, 246, 0.15);
        }

        button {
            width: 100%;
            padding: 0.95rem 1.25rem;
            background: #1d4ed8;
            color: #fff;
            border: none;
            border-radius: 14px;
            cursor: pointer;
            font-size: 1rem;
            font-weight: 700;
            transition: background 0.2s ease;
        }

        button:hover {
            background: #1e40af;
        }

        .helper {
            margin: 0.5rem 0 0;
            color: #475569;
            line-height: 1.6;
        }
    </style>
</head>

<%- include('../../partials/nav') %>
    <main class="container">
        <section class="card">
            <h2>Add Your Home</h2>
            <p class="helper">Enter your home's details to add it to the listings.</p>
            <form action="/host/add-home" method="POST" class="form-row">
                <input type="text" name="name" placeholder="Enter your home title (e.g. Cozy Studio)" required />
                <input type="number" name="price" placeholder="Enter price per night" required />
                <input type="text" name="location" placeholder="Enter your home location" required />
                <input type="number" name="ratings" placeholder="Ratings (0-10)" min="0" max="10" step="0.1" required />
                <input type="text" name="imageUrl" placeholder="Enter Image URL" required />
                <button type="submit">Submit</button>
            </form>
        </section>
    </main>
    </body>

</html>