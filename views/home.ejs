<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>airbnb-home</title>
    <style>
        body {
            margin: 0;
            font-family: Inter, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
            background: #eef2ff;
            color: #0f172a;
        }

        .navbar {
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding: 1rem 2rem;
            background: #1d4ed8;
            color: #fff;
            box-shadow: 0 6px 18px rgba(15, 23, 42, 0.12);
        }

        .navbar a {
            color: #fff;
            text-decoration: none;
            margin-left: 1.25rem;
            font-weight: 600;
        }

        .navbar a:hover {
            text-decoration: underline;
        }

        .navbar a:active {
            text-decoration: underline;
        }

        .brand {
            font-size: 1.15rem;
            font-weight: 700;
        }

        .container {
            max-width: 1080px;
            margin: 2rem auto;
            padding: 0 1.25rem;
        }

        .hero {
            text-align: center;
            margin-bottom: 2rem;
            padding: 2rem;
            background: #fff;
            border-radius: 24px;
            box-shadow: 0 10px 25px rgba(15, 23, 42, 0.08);
        }

        .hero h1 {
            margin: 0 0 0.5rem;
            font-size: clamp(2rem, 3vw, 3rem);
            color: #1e293b;
        }

        .hero p {
            margin: 0;
            color: #475569;
            line-height: 1.7;
        }

        .cards {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
            gap: 1.5rem;
        }

        .card {
            background: #ffffff;
            border-radius: 22px;
            border: 1px solid rgba(148, 163, 184, 0.18);
            box-shadow: 0 16px 30px rgba(15, 23, 42, 0.08);
            padding: 1.75rem;
            transition: transform 0.2s ease, box-shadow 0.2s ease;
        }

        .card:hover {
            transform: translateY(-4px);
            box-shadow: 0 20px 35px rgba(15, 23, 42, 0.14);
        }

        .card h2 {
            margin: 0 0 0.75rem;
            font-size: 1.35rem;
            color: #0f172a;
        }

        .card p {
            margin: 0;
            color: #475569;
            line-height: 1.65;
        }

        .empty {
            background: #e2e8f0;
            border-radius: 18px;
            padding: 2rem;
            text-align: center;
            color: #334155;
        }
    </style>
</head>

<body>
    <header class="navbar">
        <div class="brand">Airbnb Clone</div>
        <nav>
            <a href="/host/add-home">Add Home</a>
            <a href="/">Go To Home</a>
        </nav>
    </header>

    <main class="container">
        <section class="hero">
            <h1>Registered Homes</h1>
            <p>Browse the current listings below or add a new home to the collection.</p>
        </section>

        <% if (homesData && homesData.length > 0) { %>
            <section class="cards">
                <% homesData.forEach((home, index) => { %>
                    <article class="card">
                        <h2><%= home.homeName %></h2>
                        <p>Listing #<%= index + 1 %> added to the guest-ready collection.</p>
                    </article>
                <% }) %>
            </section>
        <% } else { %>
            <div class="empty">
                <p>No homes are registered yet. Use the Add Home link to create your first listing.</p>
            </div>
        <% } %>
    </main>
</body>

</html>