<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Airbnb - Home Details</title>
    <style>
        html,
        body {
            scrollbar-width: none;
            -ms-overflow-style: none;
            overflow: hidden;
            margin: 0;
            background: linear-gradient(135deg, #f8fafc 0%, #eef2ff 100%);
            font-family: Arial, Helvetica, sans-serif;
        }

        html::-webkit-scrollbar,
        body::-webkit-scrollbar {
            display: none;
        }

        .container {
            max-width: 1200px;
            width: 100%;
            margin: 2rem auto;
            padding: 0 1.25rem 2rem;
            box-sizing: border-box;
            overflow-y: auto;
            max-height: calc(100vh - 140px);
            scrollbar-width: none;
            -ms-overflow-style: none;
        }

        .container::-webkit-scrollbar {
            display: none;
        }

        .detail-card {
            background: #ffffff;
            border-radius: 28px;
            box-shadow: 0 20px 45px rgba(15, 23, 42, 0.1);
            overflow: hidden;
        }

        .back-link {
            display: inline-block;
            margin: 1.25rem 1.25rem 0;
            color: #4f46e5;
            font-weight: 700;
            text-decoration: none;
        }

        .detail-grid {
            display: grid;
            grid-template-columns: 1.1fr 0.9fr;
            gap: 1.5rem;
            padding: 1.25rem;
        }

        .image-panel img {
            width: 100%;
            height: 100%;
            min-height: 360px;
            object-fit: cover;
            border-radius: 22px;
        }

        .info-panel {
            display: flex;
            flex-direction: column;
            justify-content: center;
            padding: 0.5rem 0.25rem;
        }

        .pill-row {
            display: flex;
            flex-wrap: wrap;
            gap: 0.6rem;
            margin-bottom: 1rem;
        }

        .pill {
            display: inline-flex;
            align-items: center;
            gap: 0.35rem;
            background: #eef2ff;
            color: #4338ca;
            padding: 0.45rem 0.8rem;
            border-radius: 999px;
            font-size: 0.95rem;
            font-weight: 700;
        }

        .info-panel h1 {
            margin: 0 0 0.5rem;
            font-size: clamp(1.8rem, 2.5vw, 2.6rem);
            color: #0f172a;
        }

        .price {
            margin: 0 0 1rem;
            font-size: 1.05rem;
            color: #475569;
        }

        .price strong {
            color: #111827;
            font-size: 1.3rem;
        }

        .description {
            margin: 0 0 1.5rem;
            color: #475569;
            line-height: 1.8;
            font-size: 1rem;
        }

        

        @media (max-width: 860px) {
            .detail-grid {
                grid-template-columns: 1fr;
            }

            .image-panel img {
                min-height: 280px;
            }
        }
    </style>
</head>

<%- include('../../partials/nav') %>

    <main class="container">
        <header style="margin-bottom: 1.5rem;">
            <h1 style="text-align: center; margin:0; font-size: clamp(2rem, 3vw, 2.8rem); color:#0f172a;">Home details
            </h1>
        </header>

        <section class="detail-card">
            <a class="back-link" href="/">← Back to Home</a>

            <div class="detail-grid">
                <div class="image-panel">
                    <img src="<%= homes.imageUrl %>" alt="<%= homeName %>" />
                </div>

                <div class="info-panel">
                    <div class="pill-row">
                        <% const displayRating=(homes.ratings !==undefined && !isNaN(Number(homes.ratings))) ?
                            Number(homes.ratings).toFixed(1) : (homes.ratings || 'N/A' ); %>
                            <span class="pill">⭐ <%= displayRating %>/10</span>
                            <span class="pill">📍 <%= homes.location %></span>
                    </div>

                    <h1>
                        <%= homeName %>
                    </h1>
                    <p class="price">From <strong>₹<%= homes.price %></strong> / night</p>
                    <p class="description">
                        <%= description %>
                    </p>

                    <div>
                        <%- include("../../partials/favourites") %>
                    </div>
                </div>
            </div>
        </section>
    </main>
    </body>

</html>