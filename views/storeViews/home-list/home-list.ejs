<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>airbnb-home</title>
    <style>
        *,
        *::before,
        *::after {
            box-sizing: border-box;
        }

        body {
            margin: 0;
            font-family: Inter, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
            background: #eef2ff;
            color: #0f172a;
        }

        .navbar {
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding: 1rem 2rem;
            background: #1d4ed8;
            color: #fff;
            box-shadow: 0 6px 18px rgba(15, 23, 42, 0.12);
        }

        .navItems {
            color: #fff;
            text-decoration: none;
            margin-left: 1.25rem;
            font-weight: 600;
        }

        .navItems:hover {
            text-decoration: underline;
        }

        .navActiveItems {
            text-decoration: underline;
            font-weight: 800;
            color: #fff;
            text-underline-offset: 4px;
        }


        .brand {
            font-size: 1.15rem;
            font-weight: 700;
        }

        .container {
            max-width: 1200px;
            width: 100%;
            margin: 2rem auto;
            padding: 0 1.25rem;
            box-sizing: border-box;
        }

        .hero {
            text-align: center;
            margin-bottom: 2rem;
            padding: 2rem;
            background: #fff;
            border-radius: 24px;
            box-shadow: 0 10px 25px rgba(15, 23, 42, 0.08);
        }

        .hero h1 {
            margin: 0 0 0.5rem;
            font-size: clamp(2rem, 3vw, 3rem);
            color: #1e293b;
        }

        .hero p {
            margin: 0;
            color: #475569;
            line-height: 1.7;
        }

        .cards {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
            gap: 20px;
            justify-content: center;
            align-items: start;
        }

        .card {
            width: 100%;
            max-width: 350px;
            background: #ffffff;
            border-radius: 22px;
            border: 1px solid rgba(148, 163, 184, 0.18);
            box-shadow: 0 16px 30px rgba(15, 23, 42, 0.08);
            padding: 1.75rem;
            transition: transform 0.2s ease, box-shadow 0.2s ease;
            margin: 0 auto;
        }

        @media (max-width: 1100px) {
            .cards {
                grid-template-columns: repeat(2, 350px);
            }
        }

        @media (max-width: 760px) {
            .cards {
                grid-template-columns: 1fr;
                gap: 16px;
            }
            .card {
                max-width: none;
            }
        }

        .card:hover {
            transform: translateY(-4px);
            box-shadow: 0 20px 35px rgba(15, 23, 42, 0.14);
        }

        .home-image {
            width: 100%;
            height: 220px;
            object-fit: cover;
            display: block;
            border-radius: 8px;
            margin-bottom: 12px;
        }

        .card h2 {
            margin: 0 0 0.75rem;
            font-size: 1.35rem;
            color: #0f172a;
        }

        .card p {
            margin: 0;
            color: #475569;
            line-height: 1.65;
        }

        .empty {
            background: #e2e8f0;
            border-radius: 18px;
            padding: 2rem;
            text-align: center;
            color: #334155;
        }
    </style>
</head>

<body>
    <header class="navbar">
        <div class="brand">airbnb Clone</div>
        <nav>
            <a href="/" class="<%= currentPage == 'home' ? 'navActiveItems' : 'navItems'%>">Home</a>
            <a href="/host/add-home" class="navItems">Add Home</a>
        </nav>
    </header>

    <main class="container">
        <section class="hero">
            <h1>Registered Homes</h1>
            <p>Browse the current listings below or add a new home to the collection.</p>
        </section>

        <% if (homesData && homesData.length> 0) { %>
            <section class="cards">
                <% homesData.forEach((home, index)=> { %>
                    <article class="card">
                        <% const displayRating = (home.ratings !== undefined && !isNaN(Number(home.ratings))) ? Number(home.ratings).toFixed(1) : (home.ratings || 'N/A'); %>
                        <img src="<%= home.imageUrl %>" alt="<%= home.name || home.homeName %>" class="home-image" />
                        <hr style="height: 4px; background-color: rgba(29,78,216,0.12); border: none; margin: 10px 0;">

                        <div style="display:flex;flex-direction:column;gap:8px;">
                            <h2 style="margin:0;font-size:1.25rem;color:#0f172a;"> <%= home.name || home.homeName %> </h2>

                            <div style="display:flex;justify-content:space-between;align-items:center;gap:12px;">
                                <div style="color:#475569;font-weight:600;">INR <span style="font-weight:700;color:#0f172a;"><%= home.price %></span>
                                    <span style="font-size:0.9rem;color:#64748b;margin-left:6px;">/night</span>
                                </div>

                                <div style="color:#475569;">Rating: <span style="font-weight:700;color:#0f172a;"><%= displayRating %></span>/10</div>
                            </div>

                            <div style="color:#475569;">Location: <span style="font-weight:600;color:#0f172a;"><%= home.location %></span></div>

                            <p style="margin:0;color:#64748b;font-size:0.95rem;">Listing #<%= index + 1 %> added to the guest-ready collection.</p>
                        </div>
                    </article>
                    <% }) %>
            </section>
            <% } else { %>
                <div class="empty">
                    <p>No homes are registered yet. Use the Add Home link to create your first listing.</p>
                </div>
                <% } %>
    </main>
</body>

</html>