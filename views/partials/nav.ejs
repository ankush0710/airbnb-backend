<style>
    *,
    *::before,
    *::after {
        box-sizing: border-box;
    }

    body {
        margin: 0;
        font-family: Inter, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
        background: #eef2ff;
        color: #0f172a;
    }

    .navbar {
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding: 1rem 2rem;
        background: #659287;
        box-shadow: 0 6px 18px rgba(15, 23, 42, 0.12);
    }

    .navbar-left {
        flex: 1;
    }

    .navbar-center {
        flex: 1;
        display: flex;
        justify-content: center;
        align-items: center;
    }

    .navbar-center nav {
        display: flex;
        justify-content: center;
        align-items: center;
        gap: 0;
    }

    .navbar-right {
        flex: 1;
        display: flex;
        justify-content: flex-end;
        align-items: center;
        gap: 1.5rem;
    }

    .navbar-right nav {
        display: flex;
        justify-content: flex-end;
        align-items: center;
        gap: 0;
    }

    .page-title {
        font-size: 1.75rem;
        font-weight: 700;
        color: #fff;
    }

    .navItems {
        color: #fff;
        text-decoration: none;
        padding: 0.5rem 1rem;
        font-weight: 600;
        display: inline-block;
        transition: all 0.3s ease;
    }

    .navItems:hover {
        text-decoration: underline;
        text-underline-offset: 4px;
    }

    .navActiveItems {
        text-decoration: underline;
        font-weight: 600;
        color: #fff;
        text-underline-offset: 4px;
        padding: 0.5rem 1rem;
        display: inline-block;
    }

    .brand {
        font-size: 1.50rem;
        font-weight: 700;
        color: #233D4D;
    }

    .login-btn {
        background-color: #fff;
        color: #659287;
        border: none;
        padding: 0.6rem 1.5rem;
        border-radius: 6px;
        font-weight: 600;
        cursor: pointer;
        font-size: 1rem;
        transition: all 0.3s ease;
    }

    .login-btn:hover {
        background-color: #f0f0f0;
        transform: scale(1.05);
    }
</style>

<header class="navbar">
    <div class="navbar-left">
        <div class="brand">airbnb Clone</div>
    </div>

    <div class="navbar-center">
        <nav>
            <a href="/" class="<%= currentPage === 'Home' ? 'navActiveItems' : 'navItems' %>">Home</a>

            <% if(isLoggedIn) {%>
                <!-- <a href="/reserve" class="<%= currentPage === 'reserve' ? 'navActiveItems' : 'navItems' %>">
                Reserve
            </a>
            
             <a href="/bookings" class="<%= currentPage === 'bookings' ? 'navActiveItems' : 'navItems' %>">
                Bookings
            </a> -->

                <a href="/favourites" class="<%= currentPage === 'favourites' ? 'navActiveItems' : 'navItems' %>">
                    Favourites
                </a>

                <a href="/host/add-home" class="<%= currentPage === 'addHome' ? 'navActiveItems' : 'navItems' %>">
                    Add Home
                </a>

                <a href="/host/host-home-list"
                    class="<%= currentPage === 'host-home-list' ? 'navActiveItems' : 'navItems' %>">
                    Host Home List
                </a>

                <% } %>
        </nav>
    </div>

    <div class="navbar-right">
        <% if (isLoggedIn) { %>
            <form action="/logout" method="POST" style="margin:0;">
                <button type="submit" class="login-btn">Logout</button>
            </form>
        <% } else { %>
            <a href="/login" class="login-btn">Login</a>
        <% } %>
    </div>
</header>