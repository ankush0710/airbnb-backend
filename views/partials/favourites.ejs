
<style>
    .actions {
            display: flex;
            flex-wrap: wrap;
            gap: 0.85rem;
            margin-top: 30px;
        }

        .btn {
            text-decoration: none;
            padding: 0.8rem 1.2rem;
            border-radius: 999px;
            font-weight: 700;
            transition: transform 0.2s ease, box-shadow 0.2s ease;
            cursor: pointer;
            text-align: center;
        }

        .btn:hover {
            transform: translateY(-2px);
        }

        .btn-primary {
            background: #ef4444;
            color: #ffffff;
        }
</style>

<form action="/favourites" method="POST">
    <div class="actions">
        <button type="submit" class="btn btn-primary">♡ Add to Favourites</button>
        <input type="hidden" name="id" value="<%=homes.id %>" />
    </div>
</form>